{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Plugin",
  "description": "Schema for an individual plugin YAML file in plugins/",
  "type": "object",
  "required": ["id", "name", "version", "description", "author", "license", "homepage", "image", "manifest_url", "categories", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*\\.[a-z][a-z0-9-]+$",
      "description": "Reverse-domain plugin ID (e.g. com.nexus.cookie-jar)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "Semantic version string (e.g. 1.2.3, 1.0.0-beta.1)"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Short description of what the plugin does"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "GitHub username or org of the plugin author"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "SPDX license identifier (e.g. MIT, Apache-2.0)"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin's homepage or repository"
    },
    "image": {
      "type": "string",
      "pattern": "^[a-z0-9._/-]+(:[a-zA-Z0-9._-]+)?$",
      "description": "Docker/OCI image reference (e.g. ghcr.io/owner/plugin:version)"
    },
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "SHA-256 digest of the Docker image for integrity verification"
    },
    "manifest_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin's plugin.json manifest file"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Searchable category tags"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "unlisted"],
      "description": "Package visibility status"
    }
  }
}
