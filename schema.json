{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Plugin Registry",
  "type": "object",
  "required": ["version", "updated_at", "plugins"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Registry schema version",
      "const": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "description", "image", "manifest_url"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*\\.[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$",
            "description": "Reverse-domain plugin ID (e.g. com.nexus.cookie-jar)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable plugin name"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+",
            "description": "Semver version string"
          },
          "description": {
            "type": "string",
            "description": "Short description of the plugin"
          },
          "image": {
            "type": "string",
            "description": "Docker image name (built from the plugin's Dockerfile)"
          },
          "manifest_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the plugin's plugin.json manifest"
          },
          "categories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Searchable category tags"
          },
          "downloads": {
            "type": "integer",
            "minimum": 0,
            "description": "Download count (informational)"
          }
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "description", "manifest_url"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Extension ID"
          },
          "name": {
            "type": "string",
            "description": "Human-readable extension name"
          },
          "version": {
            "type": "string",
            "description": "Semver version string"
          },
          "description": {
            "type": "string",
            "description": "Short description"
          },
          "manifest_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the extension manifest"
          },
          "categories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "downloads": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
